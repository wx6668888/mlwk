{
  "name": "mlwk-global-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-server",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:ssr && npm run prerender",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/media/hero-film-graded.mp4';if(fs.existsSync(f)){const mb=(fs.statSync(f).size/1e6).toFixed(1);fs.unlinkSync(f);console.log('Removed '+f+' ('+mb+'MB) to stay under 25MB Cloudflare Pages limit')}else{console.log('postbuild: no oversized files to remove')}\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "aws4fetch": "^1.0.20",
    "lucide-react": "^0.468.0",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "three": "^0.181.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wrangler": "^4.23.0"
  }
}
